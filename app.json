{
  "expo": {
    "name": "YourBody",
    "slug": "yourbody",
    "version": "2.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#06081A",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourbody.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06081A"
      },
      "package": "com.yourbody.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "description": "Rahasia Tersembunyi Tubuh Manusia — Sains Modern & Kebijaksanaan Kuno",
    "extra": {
      "eas": {
        "projectId": "2eeabdd0-2cce-43c4-baa3-b6098eccc936"
      }
    },
    "owner": "darksky99",
    "plugins": [
      "expo-font"
    ]
  }
}
